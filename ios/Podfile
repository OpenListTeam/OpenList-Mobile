# Uncomment this line to define a global platform for your project
platform :ios, '12.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  
  # OpenList Framework Integration
  # Manually link xcframeworks from Frameworks directory
  target_frameworks_dir = File.expand_path('Frameworks', __dir__)
  
  if Dir.exist?(target_frameworks_dir)
    Dir.glob(File.join(target_frameworks_dir, '*.xcframework')).each do |framework_path|
      framework_name = File.basename(framework_path, '.xcframework')
      puts "Found framework: #{framework_name} at #{framework_path}"
    end
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end
  
  # Configure framework embedding
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      # Ensure framework search paths include our Frameworks directory
      config.build_settings['FRAMEWORK_SEARCH_PATHS'] ||= ['$(inherited)']
      config.build_settings['FRAMEWORK_SEARCH_PATHS'] << '$(PROJECT_DIR)/Frameworks'
      
      # Ensure proper code signing
      config.build_settings['CODE_SIGN_IDENTITY'] = ''
      config.build_settings['CODE_SIGNING_REQUIRED'] = 'NO'
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
    end
  end
  
  # Add framework embedding to Runner target
  runner_project = installer.aggregate_targets[0].user_project
  runner_target = runner_project.targets.find { |t| t.name == 'Runner' }
  
  if runner_target
    frameworks_dir = File.expand_path('Frameworks', __dir__)
    
    if Dir.exist?(frameworks_dir)
      frameworks_build_phase = runner_target.frameworks_build_phases.first
      embed_frameworks_phase = runner_target.copy_files_build_phases.find { |phase| phase.name == 'Embed Frameworks' }
      
      # Create Embed Frameworks phase if it doesn't exist
      unless embed_frameworks_phase
        embed_frameworks_phase = runner_target.new_copy_files_build_phase('Embed Frameworks')
        embed_frameworks_phase.dst_subfolder_spec = :frameworks
      end
      
      # Get or create Frameworks group
      frameworks_group = runner_project.main_group.find_subpath('Frameworks', true)
      frameworks_group.set_source_tree('SOURCE_ROOT')
      
      Dir.glob(File.join(frameworks_dir, '*.xcframework')).each do |framework_path|
        framework_name = File.basename(framework_path)
        relative_path = "Frameworks/#{framework_name}"
        
        # Check if already added
        existing_ref = frameworks_group.files.find { |f| f.path == relative_path }
        
        unless existing_ref
          puts "Adding framework to Xcode project: #{framework_name}"
          
          # Add file reference
          file_ref = frameworks_group.new_file(relative_path)
          
          # Add to Frameworks build phase
          frameworks_build_phase.add_file_reference(file_ref)
          
          # Add to Embed Frameworks phase
          build_file = embed_frameworks_phase.add_file_reference(file_ref)
          build_file.settings = { 'ATTRIBUTES' => ['CodeSignOnCopy', 'RemoveHeadersOnCopy'] }
        end
      end
      
      runner_project.save
      puts "✅ OpenList frameworks integrated successfully"
    end
  end
end
